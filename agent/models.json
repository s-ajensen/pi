{
  // Custom model definitions merged into pi's built-in providers.
  // The "anthropic" provider already exists (baseUrl, api=anthropic-messages,
  // and OAuth auth are inherited), so we only need to declare the new model.
  // The "id" MUST be the exact model string Anthropic's API expects, because
  // pi-anthropic-oauth sends model.id straight through as the request "model".
  "providers": {
    "anthropic": {
      "models": [
        {
          // ID + capabilities inferred from Claude Code 2.1.170 binary:
          // alias "fable", full name "claude-fable-5", flagship tier,
          // 1M context, default effort "high", supports xhigh thinking
          // (parallels claude-opus-4-8). Knowledge cutoff Jan 2026.
          "id": "claude-fable-5",
          "name": "Claude Fable 5",
          "reasoning": true,
          "input": ["text", "image"],
          "thinkingLevelMap": { "xhigh": "xhigh" },
          "cost": { "input": 5, "output": 25, "cacheRead": 0.5, "cacheWrite": 6.25 },
          "contextWindow": 1000000,
          "maxTokens": 128000
        }
      ]
    }
  }
}
